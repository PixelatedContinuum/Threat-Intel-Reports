---
layout: none
---
<?xml version="1.0" encoding="UTF-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title | xml_escape }}</title>
  <subtitle>{{ site.description | xml_escape }}</subtitle>
  <link href="{{ site.url }}/feed.xml" rel="self" type="application/atom+xml"/>
  <link href="{{ site.url }}/" rel="alternate" type="text/html"/>
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>{{ site.url }}/</id>
  <author>
    <name>{{ site.title | xml_escape }}</name>
    <uri>{{ site.url }}</uri>
  </author>

  {% assign reports = site.pages
     | where_exp: "page", "page.url contains '/reports/'"
     | where_exp: "page", "page.title != nil"
     | where_exp: "page", "page.date != nil"
     | sort: "date" | reverse %}

  {% for report in reports limit:20 %}
  <entry>
    <title>{{ report.title | xml_escape }}</title>
    <link href="{{ site.url }}{{ report.url }}" rel="alternate" type="text/html"/>
    <published>{{ report.date | date_to_xmlschema }}</published>
    <updated>{{ report.date | date_to_xmlschema }}</updated>
    <id>{{ site.url }}{{ report.url }}</id>
    <author>
      <name>{{ site.title | xml_escape }}</name>
      <uri>{{ site.url }}</uri>
    </author>
    <summary>{{ report.content | strip_html | truncate: 500 | xml_escape }}</summary>
  </entry>
  {% endfor %}
</feed>
